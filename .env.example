# --- REQUIRED: PostgreSQL Database (asyncpg) ---
DATABASE_URL=postgresql://quad:quad@localhost:5432/quad

# --- REQUIRED: Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=12345678,98765432

# --- REQUIRED for LIVE mode ---
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# --- REQUIRED for AI Trading Features ---
# Groq AI API key (for /analyze, /ai_strategy, trade rationale)
# Required when ai.enabled = true and you want AI-driven trading analysis.
# Get your API key at https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
